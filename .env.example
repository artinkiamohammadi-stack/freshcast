# ── Local development (SQLite, no Docker needed) ───────────────────────────
DATABASE_URL=sqlite:///./freshcast.db

# Directory where trained .pkl model files are stored
MODEL_DIR=./models

# ── Docker / production (MySQL) ────────────────────────────────────────────
# Comment out DATABASE_URL above and fill these in instead:
# DB_HOST=db
# DB_PORT=3306
# DB_USER=freshcast
# DB_PASSWORD=your_password_here
# DB_NAME=freshcast
